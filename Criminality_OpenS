local function CreateCrimHighlight(obj, color)
    local hl = obj:FindFirstChild("HyperloopHL")
    if not hl then
        hl = Instance.new("Highlight")
        hl.Name = "HyperloopHL"
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = obj
    end
    hl.FillColor = color
    hl.OutlineColor = Color3.new(1, 1, 1)
    hl.FillAlpha = 0.5
    hl.OutlineAlpha = 0
    return hl
end

local function AddLootESP(obj, lootType)
    task.spawn(function()
        local hl
        while obj and obj.Parent do
            local active = false
            if lootType == "Crate" then active = CrimConfig.ESPCrates
            elseif lootType == "Safe" then active = CrimConfig.ESPSafes
            elseif lootType == "Scrap" then active = CrimConfig.ESPScrap end

            hl = obj:FindFirstChild("HyperloopHL")
            if active then
                local targetColor = Color3.fromRGB(255, 255, 255)
                if lootType == "Scrap" then
                    targetColor = Color3.fromRGB(255, 0, 0)
                elseif lootType == "Safe" then
                    local values = obj:FindFirstChild("Values")
                    local broken = values and values:FindFirstChild("Broken")
                    if broken and (tostring(broken.Value) == "1" or broken.Value == true) then
                        targetColor = Color3.fromRGB(255, 0, 0)
                    else
                        targetColor = Color3.fromRGB(0, 255, 0)
                    end
                elseif lootType == "Crate" then
                    local mesh = obj:IsA("MeshPart") and obj or obj:FindFirstChildWhichIsA("MeshPart", true)
                    if mesh and string.find(tostring(mesh.TextureID), "11157915894") then
                        targetColor = Color3.fromRGB(255, 0, 0)
                    else
                        targetColor = Color3.fromRGB(0, 255, 0)
                    end
                end
                if not hl then hl = CreateCrimHighlight(obj, targetColor) end
                hl.Enabled = true
                hl.FillColor = targetColor
            else
                if hl then hl.Enabled = false end
            end
            task.wait(0.5)
        end
        if hl then hl:Destroy() end
    end)
end

local function scanLoot(v)
    local nm = v.Name
    if nm == "S1" or nm == "S2" then
        AddLootESP(v, "Scrap")
    elseif nm == "SmallSafe" or nm == "MediumSafe" then
        AddLootESP(v, "Safe")
    elseif nm == "C1" then
        AddLootESP(v, "Crate")
    end
end

