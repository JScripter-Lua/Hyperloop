local CrimFOV = Drawing.new("Circle"); CrimFOV.Visible = false; CrimFOV.Color = Color3.new(1,1,1); CrimFOV.Thickness = 1

RunService.RenderStepped:Connect(function()
    CrimFOV.Visible = CrimConfig.Aimlock
    CrimFOV.Radius  = CrimConfig.AimFOV
    CrimFOV.Position = Vector2.new(Mouse.X, Mouse.Y + GuiService:GetGuiInset().Y)

    if CrimConfig.FullBright then
        Lighting.Brightness    = 2
        Lighting.ClockTime     = 14
        Lighting.Ambient       = Color3.new(1,1,1)
        Lighting.OutdoorAmbient = Color3.new(1,1,1)
        Lighting.GlobalShadows = false
    end

    if CrimConfig.Aimlock and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local targetPart = nil
        local minDistance = CrimConfig.AimFOV
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(CrimConfig.AimPart) then
                local char = v.Character
                local part = char[CrimConfig.AimPart]
                local screenPos, onScreen = CrimCamera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mouseDist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if mouseDist < minDistance then
                        local isVisible = true
                        if CrimConfig.WallCheck then
                            local rayParams = RaycastParams.new()
                            rayParams.FilterType = Enum.RaycastFilterType.Exclude
                            rayParams.FilterDescendantsInstances = {LocalPlayer.Character, char}
                            local origin = CrimCamera.CFrame.Position
                            local direction = (part.Position - origin).Unit * (part.Position - origin).Magnitude
                            local rayResult = workspace:Raycast(origin, direction, rayParams)
                            if rayResult then isVisible = false end
                        end
                        if isVisible then minDistance = mouseDist; targetPart = part end
                    end
                end
            end
        end
        if targetPart then
            local finalPos = targetPart.Position + (targetPart.Velocity * CrimConfig.Prediction)
            CrimCamera.CFrame = CrimCamera.CFrame:Lerp(CFrame.new(CrimCamera.CFrame.Position, finalPos), CrimConfig.Smoothness)
        end
    end
end)

